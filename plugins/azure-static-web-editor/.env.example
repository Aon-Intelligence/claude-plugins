# Copy to .env in this directory and fill in values.
# run-server.sh loads .env automatically when present.

# Wrap in single quotes — semicolons in the connection string break shell sourcing.
AZURE_STORAGE_CONNECTION_STRING='DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT;AccountKey=YOUR_KEY;EndpointSuffix=core.windows.net'
AZURE_STORAGE_CONTAINER_NAME='$web'
OPENAI_API_KEY=
# Image model for generate_image (default: gpt-image-1)
OPENAI_IMAGE_MODEL=gpt-image-1

# Server bind (use 0.0.0.0 inside Docker / Azure Container Apps)
MCP_HOST=127.0.0.1
MCP_PORT=8000

# streamable-http (recommended) or legacy sse
MCP_TRANSPORT=streamable-http
