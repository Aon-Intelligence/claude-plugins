{
  "mcpServers": {
    "static-web-editor": {
      "command": "${CLAUDE_PLUGIN_ROOT}/server/run-server.sh",
      "env": {
        "AZURE_STORAGE_CONNECTION_STRING": "${user_config.AZURE_STORAGE_CONNECTION_STRING}",
